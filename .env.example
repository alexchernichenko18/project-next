# Backend (NestJS) base URL. Used by REST + socket.io client.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Google Identity Services client ID for "Sign in with Google".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Sentry — separate Next.js project, distinct from the NestJS backend's DSN.
# DSN is safe to expose in the client bundle (NEXT_PUBLIC_*).
NEXT_PUBLIC_SENTRY_DSN=

# Build-time only — used by withSentryConfig to upload source maps.
# Generate at https://sentry.io/orgredirect/organizations/:org/settings/auth-tokens/
SENTRY_AUTH_TOKEN=

# Org and project slugs (visible in the Sentry URL).
SENTRY_ORG=
SENTRY_PROJECT=
